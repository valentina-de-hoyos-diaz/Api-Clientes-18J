<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
</head>
<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div class="jumbotron">
            <h1>Nuestros productos</h1>
            <table border="5px" class="table table-striped text-center">
                <thead>
                    <th>N°</th>
                    <th>Producto</th>
                    <th>Precio</th>
                    <th>Descripción</th>
                    <th>Categoría</th>
                    <th>Imagen</th>
                </thead>
                <tbody>
                    <% productos.forEach(function(producto) { %>
                    <tr>
                        <td><%= producto.id %></td>
                        <td><%= producto.title %></td>
                        <td>$<%= producto.price %></td>
                        <td><%= producto.description %></td>
                        <td><%= producto.category %></td>
                        <td><img src="<%= producto.image %>" alt="<%= producto.title %>" width="80px"></td>
                    </tr>
                    <% }); %>
                </tbody>

            </table>
        </div>
    
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>


</body>
</html>
